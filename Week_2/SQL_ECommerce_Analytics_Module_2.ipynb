    "print(\"==================================================================\")\n",
    "print(\"       SECTION E: CONDITIONAL LOGIC & ATOMIC TRANSACTIONS         \")\n",
    "print(\"==================================================================\")\n",
    "\n",
    "# Q24: Write a query using CASE to classify products into price tiers\n",
    "print(\"\\n--- Q24: Dynamic Product Inventory Price Tier Matrix ---\")\n",
    "q24_query = \"\"\"\n",
    "SELECT \n",
    "    product_name, \n",
    "    unit_price,\n",
    "    CASE \n",
    "        WHEN unit_price < 1000 THEN 'Budget'\n",
    "        WHEN unit_price BETWEEN 1000 AND 3000 THEN 'Mid-Range'\n",
    "        ELSE 'Premium' \n",
    "    END AS price_tier\n",
    "FROM products;\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q24_query, session_db))\n",
    "\n",
    "# Q25: Use a CASE statement inside an aggregate function to pivot order compliance status\n",
    "print(\"\\n--- Q25: Order Fulfillment Pivot (Single-Row Compliance Vector) ---\")\n",
    "q25_query = \"\"\"\n",
    "SELECT \n",
    "    COUNT(CASE WHEN status = 'Delivered' THEN 1 END) AS delivered_volume,\n",
    "    COUNT(CASE WHEN status != 'Delivered' THEN 1 END) AS non_delivered_volume\n",
    "FROM orders;\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q25_query, session_db))\n",
    "\n",
    "# Q26: Theoretical breakdown of ACID architecture properties\n",
    "print(\"\\n--- Q26: Architectural ACID Robustness Evaluation ---\")\n",
    "print(\"Theoretical Framework Analysis:\")\n",
    "print(\"* Atomicity: Guarantees that an entire transaction occurs as a single unit of work—either every single statement succeeds, or the database is rolled back to its exact starting state. (e.g., In a bank transfer, deducting money from Account A without depositing it into Account B is completely blocked).\")\n",
    "print(\"* Consistency: Enforces that any transaction moves the database from one valid state to another, preserving all strict structural schema rules, constraints, and relationships.\")\n",
    "print(\"* Isolation: Ensures that concurrently running operations cannot see each other's uncommitted intermediate data states, preventing race conditions or dirty reads.\")\n",
    "print(\"* Durability: Guarantees that once a transaction commits, its modifications are written permanently to non-volatile disk storage. The data will survive even a sudden system crash or power loss.\")\n",
    "\n",
    # Programmable Multi-Step Atomic Transaction Execution Block
print("\\n--- Q27: Multi-Statement Atomic Transaction Verification Block ---")
print("[System Log] Initializing sandboxed transaction engine parameters...")

try:
    # Ensure active schema configurations have the proper index physical footprints
    session_db.execute("CREATE INDEX IF NOT EXISTS idx_orders_date ON orders(order_date);")
    
    # Context Manager utilization to automatically scale runtime checks seamlessly
    with session_db:
        # Task step 1: Insert the master order record
        order_insertion_query = "INSERT INTO orders VALUES (1011, 102, '2026-05-30', 'Pending', 1598.00);"
        session_db.execute(order_insertion_query)
        print(" -> Step 1 Verified: Order header record created successfully.")
        
        # Task step 2: Append itemized individual stock ledger units
        item_1_query = "INSERT INTO order_items VALUES (5016, 1011, 202, 1, 799.00, 0);"
        item_2_query = "INSERT INTO order_items VALUES (5017, 1011, 202, 1, 799.00, 0);"
        session_db.execute(item_1_query)
        session_db.execute(item_2_query)
        print(" -> Step 2 Verified: Linked order items appended to sub-ledger table.")
        
        # Task step 3: Re-balance active product warehouse allocations (deducting stock)
        inventory_sync_query = "UPDATE products SET stock_qty = stock_qty - 2 WHERE product_id = 202;"
        session_db.execute(inventory_sync_query)
        print(" -> Step 3 Verified: Warehouse inventory quantities synchronized.")
        
    print("\\n[Transaction Success] All steps completed without failure. Changes COMMITTED to storage safely.")

except Exception as transaction_error:
    # Isolation recovery strategy setup 
    session_db.rollback()
    print(f"\\n[Transaction Failure] Emergency rollback activated. Details: {transaction_error}")

# Run data quality count checks to verify the transaction executed perfectly
