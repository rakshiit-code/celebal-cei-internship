    "print(\"==================================================================\")\n",
    "print(\"       SECTION B: FILTERING & STRUCTURAL OPTIMIZATION             \")\n",
    "print(\"==================================================================\")\n",
    "\n",
    "# Q7: Retrieve all orders with status = 'Delivered'\n",
    "print(\"\\n--- Q7: Delivered Orders Registry Exploration ---\")\n",
    "q7_query = \"SELECT * FROM orders WHERE status = 'Delivered';\"\n",
    "display(pd.read_sql_query(q7_query, session_db))\n",
    "\n",
    "# Q8: Find all products in 'Electronics' with a unit_price > 2000\n",
    "print(\"\\n--- Q8: High-Value Electronics Inventory ---\")\n",
    "q8_query = \"SELECT * FROM products WHERE category = 'Electronics' AND unit_price > 2000;\"\n",
    "display(pd.read_sql_query(q8_query, session_db))\n",
    "\n",
    "# Q9: List all customers who joined in the year 2024 and belong to the state 'Maharashtra'\n",
    "print(\"\\n--- Q9: 2024 Maharashtra Customer Ingestion Check ---\")\n",
    "q9_query = \"SELECT * FROM customers WHERE join_date LIKE '2024%' AND state = 'Maharashtra';\"\n",
    "display(pd.read_sql_query(q9_query, session_db))\n",
    "\n",
    "# Q10: Find all orders placed between '2024-08-10' and '2024-08-25' (inclusive) that are NOT cancelled\n",
    "print(\"\\n--- Q11: Active Non-Cancelled Mid-August Transactions ---\")\n",
    "q10_query = \"\"\"\n",
    "SELECT * FROM orders \n",
    "WHERE order_date BETWEEN '2024-08-10' AND '2024-08-25' \n",
    "  AND status != 'Cancelled';\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q10_query, session_db))\n",
    "\n",
    "# Q11: Explain index idx_orders_date performance impact textually\n",
    "print(\"\\n--- Q11: Index Acceleration Analysis ---\")\n",
    "print(\"Explanation: The index 'idx_orders_date' functions as a pre-sorted lookup map.\")\n",
    "print(\"Instead of a costly Full Table Scan (O(N)), where the engine must check every single row sequentially, the index enables a Binary Range Scan (O(log N)) to jump directly to matching dates.\")\n",
    "print(\"\\nSample Query utilizing this index:\")\n",
    "print(\"SELECT * FROM orders WHERE order_date = '2024-08-15';\")\n",
    "\n",
    "# Q12: SARGable query evaluation and modification\n",
    "print(\"\\n--- Q12: Index-Friendly (SARGable) Query Modification ---\")\n",
    "print(\"Analysis: If you execute 'SELECT * FROM customers WHERE YEAR(join_date) = 2024', the index will NOT be used.\")\n",
    "print(\"Wrapping the column in a function like YEAR() forces the engine to compute the function for every single row, breaking the index's pre-sorted layout.\")\n",
    "print(\"\\nRewritten SARGable Query (Using explicit date boundary constants instead):\")\n",
    "q12_sargable_query = \"\"\"\n",
    "SELECT * FROM customers \n",
    "WHERE join_date >= '2024-01-01' \n",
    "  AND join_date <= '2024-12-31';\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q12_sargable_query, session_db))"
   ]
  },
