   "source": [
    "print(\"\\n--- BONUS USE CASE: Data Quality Audit (Duplicate & Integrity Verification) ---\")\n",
    "dq_duplicate_query = \"\"\"\n",
    "SELECT email, COUNT(*) AS distribution_count \n",
    "FROM customers \n",
    "GROUP BY email \n",
    "HAVING COUNT(*) > 1;\n",
    "\"\"\"\n",
    "print(\"[Validation Log] Checking for duplicate master records:\")\n",
    "audit_df = pd.read_sql_query(dq_duplicate_query, session_db)\n",
    "if audit_df.empty:\n",
    "    print(\" -> Success! Zero duplicate email records discovered inside the customer schema.\")\n",
    "else:\n",
    "    display(audit_df)"
   ]
