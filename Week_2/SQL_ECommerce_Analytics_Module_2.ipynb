   "source": [
    "print(\"==================================================================\")\n",
    "print(\"       SECTION C: EXECUTIVE DATA SUMMARIZATION & AGGREGATIONS     \")\n",
    "print(\"==================================================================\")\n",
    "\n",
    "# Q13: Count the total number of orders in the orders table\n",
    "print(\"\\n--- Q13: Global Transaction Volume Matrix ---\")\n",
    "q13_query = \"SELECT COUNT(*) AS total_processed_orders FROM orders;\"\n",
    "display(pd.read_sql_query(q13_query, session_db))\n",
    "\n",
    "# Q14: Find the total revenue from all 'Delivered' orders\n",
    "print(\"\\n--- Q14: Realized Gross Revenue (Delivered Liquidation) ---\")\n",
    "q14_query = \"SELECT SUM(total_amount) AS realized_gross_revenue FROM orders WHERE status = 'Delivered';\"\n",
    "display(pd.read_sql_query(q14_query, session_db))\n",
    "\n",
    "# Q15: Calculate the average unit_price of products in each category\n",
    "print(\"\\n--- Q15: Average Category Catalog Valuation ---\")\n",
    "q15_query = \"SELECT category, ROUND(AVG(unit_price), 2) AS mean_unit_price FROM products GROUP BY category;\"\n",
    "display(pd.read_sql_query(q15_query, session_db))\n",
    "\n",
    "# Q16: For each order status, find the count of orders and total revenue sorted by revenue desc\n",
    "print(\"\\n--- Q16: Pipeline Performance Breakdown by Order Status ---\")\n",
    "q16_query = \"\"\"\n",
    "SELECT \n",
    "    status, \n",
    "    COUNT(*) AS total_order_count, \n",
    "    SUM(total_amount) AS accumulated_revenue \n",
    "FROM orders \n",
    "GROUP BY status \n",
    "ORDER BY accumulated_revenue DESC;\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q16_query, session_db))\n",
    "\n",
    "# Q17: Find the most expensive (MAX) and cheapest (MIN) product in each category\n",
    "print(\"\\n--- Q17: Inventory Pricing Extremes (Floor vs Peak Bounds) ---\")\n",
    "q17_query = \"\"\"\n",
    "SELECT \n",
    "    category, \n",
    "    MAX(unit_price) AS premium_peak_price, \n",
    "    MIN(unit_price) AS economic_floor_price \n",
    "FROM products \n",
    "GROUP BY category;\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q17_query, session_db))\n",
    "\n",
    "# Q18: List all product categories where the average unit_price is greater than 2000\n",
    "print(\"\\n--- Q18: Premium Sector Isolation via HAVING Constraint ---\")\n",
    "q18_query = \"\"\"\n",
    "SELECT \n",
    "    category, \n",
    "    ROUND(AVG(unit_price), 2) AS premium_sector_average \n",
    "FROM products \n",
    "GROUP BY category \n",
    "HAVING AVG(unit_price) > 2000;\n",
    "\"\"\"\n",
    "display(pd.read_sql_query(q18_query, session_db))"
   ]
  },
