   "source": [
    "print(\"==================================================================\")\n",
    "print(\"       SECTION A: RELATIONAL BASICS & CONSTRAINT VERIFICATION     \")\n",
    "print(\"==================================================================\")\n",
    "\n",
    "# Q1: Display all columns and rows from the customers table\n",
    "print(\"\\n--- Q1: Full Customer Registry Audit ---\")\n",
    "q1_query = \"SELECT * FROM customers;\"\n",
    "display(pd.read_sql_query(q1_query, session_db))\n",
    "\n",
    "# Q2: Retrieve only first_name, last_name, and city of all customers\n",
    "print(\"\\n--- Q2: Targeted Geographic Profiles ---\")\n",
    "q2_query = \"SELECT first_name, last_name, city FROM customers;\"\n",
    "display(pd.read_sql_query(q2_query, session_db))\n",
    "\n",
    "# Q3: List all unique categories available in the products table\n",
    "print(\"\\n--- Q3: Unique Product Category Inventory ---\")\n",
    "q3_query = \"SELECT DISTINCT category FROM products;\"\n",
    "display(pd.read_sql_query(q3_query, session_db))\n",
    "\n",
    "# Q4: Identify Primary Keys and explain their constraints textually\n",
    "print(\"\\n--- Q4: Primary Key Structural Identification ---\")\n",
    "print(\"Primary Keys Identified: customers(customer_id), products(product_id), orders(order_id), order_items(item_id).\")\n",
    "print(\"Explanation: A Primary Key is a foundational relational rule. It must be UNIQUE and NOT NULL to satisfy entity integrity, ensuring that every record can be distinctly identified and preventing corrupt orphaned rows inside database memory.\")\n",
    "\n",
    "# Q5: Constraints on the email column and duplicate insert behavior\n",
    "print(\"\\n--- Q5: Column Constraint Analysis (Email Field) ---\")\n",
    "print(\"Applied Constraints: UNIQUE and NOT NULL.\")\n",
    "print(\"System Behavior: If an operation attempts to write an identical email string, the transactional layer will instantly trip a 'Constraint Violation Exception' and force an immediate rollback of that statement to protect data sanitization.\")\n",
    "\n",
    "# Q6: Test negative price constraint violation safely\n",
    "print(\"\\n--- Q6: Active Integrity Constraint Simulation (unit_price = -50) ---\")\n",
    "negative_insert_stmt = \"INSERT INTO products VALUES (210, 'Faulty Prototype', 'Electronics', 'Generic', -50.00, 15);\"\n",
    "try:\n",
    "    engine.execute(negative_insert_stmt)\n",
    "    session_db.commit()\n",
    "    print(\"[Alert] The insertion unexpectedly bypassed constraints.\")\n",
    "except sqlite3.IntegrityError as constraint_exception:\n",
    "    print(f\"[Verification Success] Relational engine safely blocked the operation!\")\n",
    "    print(f\"Triggered Exception Trace: {constraint_exception}\")\n",
    "    print(\"Explanation: The 'CHECK (unit_price > 0)' clause applied to the products table stopped the statement because a value of -50 explicitly breaks the rule.\")"
   ]
  },
